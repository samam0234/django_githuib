#.gitignore
.env

# ----------------------
# Python 기본
# ----------------------
__pycache__/
*.py[cod]
*$py.class

# ----------------------
# 가상환경 (중요)
# ----------------------
venv/
env/
ENV/
.venv/

# ----------------------
# Django 설정 파일
# ----------------------
*.log
*.pot
*.pyc
db.sqlite3
db.sqlite3-journal

# ----------------------
# 미디어 / 업로드 파일
# ----------------------
media/

# ----------------------
# 정적 파일 (collectstatic 결과)
# ----------------------
static/

# ----------------------
# 환경 변수 파일 (중요 - 보안)
# ----------------------
.env
.env.*

# ----------------------
# Django Secret Key 보호
# ----------------------
# settings_local.py 같은 파일 사용 시
settings_local.py

# ----------------------
# IDE / 에디터
# ----------------------
.vscode/
.idea/
*.swp
*.swo

# ----------------------
# OS 관련 파일
# ----------------------
.DS_Store
Thumbs.db

# ----------------------
# 테스트 / 커버리지
# ----------------------
.coverage
htmlcov/
.pytest_cache/

# ----------------------
# 배포 관련
# ----------------------
*.pem
*.key
*.crt

# ----------------------
# 기타
# ----------------------
*.bak
*.tmp